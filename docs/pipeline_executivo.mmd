---
title: "Pipeline Simplificado · Detector de Erros de Layout em UI"
---
%%{init: {
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Segoe UI, Helvetica, Arial, sans-serif",
    "fontSize": "15px",
    "lineColor": "#607D8B",
    "primaryTextColor": "#1A2027"
  },
  "flowchart": { "curve": "basis", "nodeSpacing": 60, "rankSpacing": 70 }
}}%%
flowchart TB
    %% A linha grossa (==>) indica o fluxo principal da inferência (teste).

    %% --- ETAPA 1: DADOS ---
    subgraph S1["1. Fontes de Dados"]
        direction TB
        D1["Telas LIMPAS Reais<br/>(Um Único Dispositivo)"]:::dados
        D2["Telas COM ERRO Reais<br/>(Vários Dispositivos)"]:::dados
    end

    %% --- ETAPA 2: A SOLUÇÃO DO CONFINAMENTO ---
    subgraph S2["2. Geração de Sintéticos (Anti-Confound)"]
        direction TB
        SYN["🧪 Injeta erros artificiais nas Telas LIMPAS<br/>(Mesma resolução original)"]:::synth
        NOTE_SYN["> Garante que o modelo aprenda o erro,<br/>não o dispositivo."]:::note_clear
        SYN --- NOTE_SYN
    end

    %% --- ETAPA 3: PROCESSAMENTO ---
    subgraph S3["3. Extração de Características"]
        direction TB
        PRE["Pré-processamento<br/>(Pad/Resize sem distorção)"]:::preproc
        BB["🔒 Backbone DINOv2<br/>(Congelado — Não aprende)"]:::frozen
        PRE ==> BB
    end

    %% --- ETAPA 4: REDE SIAMESA ---
    subgraph S4["4. Aprendizado Métrico"]
        direction TB
        HEAD["🎯 Cabeça de Projeção<br/>(Treinável — Aprende a separar)"]:::head
        Z["Vetor z na Hiperesfera<br/>(Espaço de busca)"]:::head
        HEAD ==> Z
    end

    %% --- ETAPA 5: DECISÃO ---
    subgraph S5["5. Decisão (One-Class)"]
        direction TB
        PROTO["Protótipos do Cluster LIMPO<br/>(Definem o que é 'normal')"]:::decis
        DIST["Compara tela-alvo com Protótipos<br/>(Mede distância cossoidal)"]:::decis
        SCORE["Cálculo da Probabilidade de Erro"]:::decis
        DEC{"Há Erro?<br/>p(erro) ≥ limiar"}:::decis

        DIST ==> SCORE ==> DEC
        PROTO -.-> DIST
    end

    %% --- ETAPA 6: RESULTADO ---
    RES["❌ TELA COM ERRO<br/>ou<br/>✅ TELA LIMPA"]:::result

    %% === CONEXÕES MACRO (FLUXOS DO PIPELINE) ===
    
    %% Fluxo de Treino: Preparação contra o Confound
    D1 ==> SYN
    SYN ==> PRE

    %% Fluxo Global: Imagens reais (erros e limpas) entram no pré-proc
    D2 ==> PRE

    %% Conexão Pré-proc -> Extração
    BB ==> HEAD

    %% Conexão Aprendizado -> Decisão
    Z ==> DIST
    Z -.->|"(Define os protótipos durante o treino)"| PROTO

    %% Resultado Final
    DEC ==> RES

    %% === ESTILOS E LEGENDA ===
    classDef dados   fill:#E3F2FD,stroke:#1565C0,stroke-width:1px,color:#0D47A1;
    classDef synth   fill:#FFF3E0,stroke:#E65100,stroke-width:2px,color:#BF360C;
    classDef preproc fill:#E0F2F1,stroke:#00695C,stroke-width:1px,color:#004D40;
    classDef frozen  fill:#ECEFF1,stroke:#455A64,stroke-width:1.5px,color:#263238;
    classDef head    fill:#E8F5E9,stroke:#2E7D32,stroke-width:1.5px,color:#1B5E20;
    classDef decis   fill:#F3E5F5,stroke:#6A1B9A,stroke-width:1px,color:#4A148C;
    classDef result  fill:#37474F,stroke:#263238,stroke-width:2px,color:#FFFFFF,font-weight:bold;
    classDef note_clear fill:none,stroke:none,color:#546E7A,font-style:italic;

    style S1 fill:#F5FAFF,stroke:#90CAF9,color:#1565C0
    style S2 fill:#FFF8F0,stroke:#FFB74D,color:#E65100
    style S3 fill:#F2FBFA,stroke:#80CBC4,color:#00695C
    style S4 fill:#F4FBF4,stroke:#A5D6A7,color:#2E7D32
    style S5 fill:#FBF4FD,stroke:#CE93D8,color:#6A1B9A