graph TD
    %% =====================================================================
    %% Pipeline — UI layout-error detector (siamese head over frozen DINOv2)
    %% Dataset: data/processed_v3 · Two stages: (1) "is there an error?" gate · (2) error category
    %% Reflects the FROZEN config used in the experiments (configs/default.yaml)
    %% =====================================================================

    %% ---------- 1. DATA SOURCES ----------
    subgraph S1["1 · Data sources (raw · data/input)"]
        direction TB
        CLEAN["clean screens<br/>172 real · ALL 2076×2152 — single device<br/>⚠ resolution confound (also single form-factor)"]
        ERR["real errors · 4 categories<br/>277 real · black_bars · disordered_layout ·<br/>empty_space · overlay<br/>(distortion + orientation REMOVED)"]
    end

    %% ---------- 2. SPLIT + SINGLE SOURCE OF TRUTH ----------
    SPLIT["rebuild_processed_v3.py<br/>dedup (717→449 unique) · grouped by ticket<br/>+ stratified · 0 leakage<br/>train 273 real · val 68 · test 108"]
    PROC[("data/processed_v3/ — SINGLE SOURCE OF TRUTH<br/>flat layout + labels.csv (path,split,source,category,…)")]

    %% ---------- 3. ANTI-CONFOUND AUGMENTATION (train only) ----------
    subgraph S3["3 · Anti-confound augmentation (train only)"]
        direction TB
        SYN["Synthetic ERRORS injected in clean screens<br/>SAME resolution (synthetic.py · +419)<br/>→ breaks confound from the ERROR side"]
        REF["REFLOW clean variants + benign aug (reflow.py · +420)<br/>scroll · dual-pane · aspect-ratio · spacing<br/>+ resolution round-trip → breaks confound from the CLEAN side"]
    end

    %% ---------- 4. BACKBONE + FEATURES ----------
    PRE["Preprocess: gray-pad to 518×518 + patch mask<br/>(geometry.py · masks padding in patch stats)"]
    BB["DINOv2 ViT-S/14 ❄ FROZEN<br/>CLS + mean/std of CONTENT patch tokens = 1152-d"]
    EMB[("Cached embeddings .npz<br/>artifacts/embeddings/")]

    %% ---------- 5. TRAINING (only trainable part) ----------
    HEAD["Siamese projection head g(·) 🎯 TRAINABLE (~314k)<br/>1152 → 256 → z ∈ 64-d (L2-normalized)<br/>Loss = SupCon(z, τ=0.1) + 0.3·CE(aux, 5 classes)<br/>early-stop on confound-free val gate (AUROC)"]

    %% ---------- 6. TWO-STAGE DECISION ----------
    subgraph S6["6 · Two-stage decision"]
        direction TB
        G1{"Stage 1 — GATE: is there an error?<br/>fusion[dist. to clean prototype, 1−P(clean)]<br/>threshold = specificity-first (target 0.80)<br/>calibrated on confound-free val"}
        G2["Stage 2 — CATEGORY (only if error)<br/>nearest category prototype in z-space<br/>→ 4 fine classes / 2 coarse super-classes"]
    end

    %% ---------- 7. HONEST EVALUATION + OUTPUTS ----------
    subgraph S7["7 · Honest evaluation & outputs"]
        direction TB
        EVAL["evaluate.py --final-test<br/>(test LOCKED by protocol · read once)<br/>vs confound baselines · falsifiability · 95% CI"]
        REP["run_experiment.py → EXPERIMENT_RESULTS.md/.json<br/>report_processed_v3.py → confusion matrices<br/>(binary + 5-class) · per-class precision/recall/AUROC"]
        VIZ["clusters train/test by category<br/>(PNG + interactive HTML · UMAP of z)"]
    end

    %% ===================== EDGES =====================
    CLEAN --> SPLIT
    ERR --> SPLIT
    SPLIT -->|"materialize"| PROC
    CLEAN -. "inject errors (same res)" .-> SYN
    CLEAN -. "legit layout changes" .-> REF
    PROC -->|"scan labels.csv"| PRE
    SYN -->|"train only"| PRE
    REF -->|"train only"| PRE
    PRE --> BB
    BB -->|"extract"| EMB
    EMB -->|"fast train (frozen backbone)"| HEAD
    HEAD -->|"z + aux logits"| G1
    G1 -->|"yes → error"| G2
    G1 -->|"score / threshold"| EVAL
    G2 -->|"category"| EVAL
    EVAL --> REP
    HEAD -. "z-space (UMAP)" .-> VIZ
    G1 -. "operating point" .-> VIZ

    %% ===================== STYLES =====================
    classDef source   fill:#E3F2FD,stroke:#1565C0,color:#0D47A1;
    classDef split    fill:#E8EAF6,stroke:#3949AB,color:#1A237E;
    classDef synth    fill:#FFF3E0,stroke:#E65100,color:#BF360C;
    classDef frozen   fill:#ECEFF1,stroke:#455A64,color:#263238;
    classDef proc     fill:#E0F2F1,stroke:#00695C,color:#004D40;
    classDef store    fill:#E8F5E9,stroke:#2E7D32,color:#1B5E20;
    classDef train    fill:#F3E5F5,stroke:#6A1B9A,color:#4A148C;
    classDef decision fill:#FCE4EC,stroke:#AD1457,color:#880E4F;
    classDef output   fill:#FFFDE7,stroke:#F9A825,color:#F57F17;

    class CLEAN,ERR source;
    class SPLIT split;
    class SYN,REF synth;
    class BB frozen;
    class PRE proc;
    class PROC,EMB store;
    class HEAD train;
    class G1,G2 decision;
    class EVAL,REP,VIZ output;

    style S1 fill:#F5FAFF,stroke:#90CAF9,color:#1565C0
    style S3 fill:#FFF8F0,stroke:#FFB74D,color:#E65100
    style S6 fill:#FDF1F5,stroke:#F48FB1,color:#AD1457
    style S7 fill:#FFFEF2,stroke:#FFE082,color:#F9A825
